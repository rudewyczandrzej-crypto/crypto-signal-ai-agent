# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key

# Groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# Bybit V5 public market API
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_CATEGORY=linear

# Signal scan
SIGNAL_SCAN_INTERVAL_SECONDS=900
SIGNAL_MANAGE_INTERVAL_SECONDS=300

MIN_AI_SIGNAL_SCORE=7
MAX_CANDIDATES_PER_SCAN=20
MAX_SIGNALS_PER_SCAN=3

SIGNAL_COOLDOWN_HOURS=6
MAX_OPEN_SIGNALS=5
MAX_OPEN_SIGNALS_PER_SYMBOL=1

MAX_LEVERAGE_CAP=5
DEFAULT_MAX_HOLD_MINUTES=240

MIN_24H_QUOTE_VOLUME=50000000
MIN_VOLUME_SPIKE=1.25

AI_TEMPERATURE=0.15

DISCOVERY_NEWS_ENABLED=true
NEWS_FEEDS=https://cointelegraph.com/rss,https://www.coindesk.com/arc/outboundfeeds/rss/,https://decrypt.co/feed

HEALTH_ALERT_COOLDOWN_SECONDS=1800
